# Copy to backend.hcl (repo root), edit values, then from AWS/:
#
#   terraform init -reconfigure -backend-config=../backend.hcl
#
# IAM user/role behind profile must allow S3 state bucket + DynamoDB lock table.
# See policies/terraform-state-backend.json.example.

bucket         = "YOUR_STATE_BUCKET"
# Networking: networking/dev/terraform.tfstate
# ECS:       ecs/dev/terraform.tfstate
key            = "networking/dev/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "YOUR_LOCK_TABLE"
profile        = "terraform-infra"
